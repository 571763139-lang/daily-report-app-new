@echo off
:: 设置控制台为 UTF-8 编码，防止中文乱码
chcp 65001 >nul
title 生产日报静态服务 - 本地测试

echo =======================================================
echo    🚀 生产日报智能填报与校验系统 (无服务器本地启动)
echo =======================================================
echo.
echo [1/1] 正在启动本地静态 Web 容器服务...
echo.
echo =======================================================
echo  请在浏览器中打开并使用: http://127.0.0.1:5000
echo  (如需关闭服务，直接关闭此黑窗口或按 Ctrl+C)
echo =======================================================
echo.

:: 启动 Python 原生的极轻量静态 Web 服务，规避 file:// 协议的 fetch CORS 拦截
python -m http.server 5000

if %errorlevel% neq 0 (
    echo.
    echo ❌ 服务启动失败，错误代码: %errorlevel%
    pause
)
